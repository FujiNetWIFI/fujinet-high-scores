[Unit]
Description=CoCo Downland Hi-scores
After=remote-fs.target
After=syslog.target

# replace paths to match your TNFS directory and web root

[Service]
User=root
Group=root
ExecStart=/usr/local/sbin/coco-downland "/tnfs/coco/DOWNLAND-HS.DSK" "/var/www/html/coco-downland.html"

[Install]
WantedBy=multi-user.target
